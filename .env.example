# ── Option A: Vertex AI (bills to Google Cloud — use this for Trial GenAI Credit) ──
# The server uses Vertex AI when GOOGLE_CLOUD_PROJECT is set (or GOOGLE_GENAI_USE_VERTEXAI=true).
# Authenticate with Application Default Credentials before running:
#   gcloud auth application-default login
# or point GOOGLE_APPLICATION_CREDENTIALS at a service-account key file.
# Preview models (gemini-3.1-pro-preview) are only served on the "global" endpoint.
GOOGLE_GENAI_USE_VERTEXAI="true"
GOOGLE_CLOUD_PROJECT="my-gcp-project-id"
GOOGLE_CLOUD_LOCATION="global"
# GOOGLE_APPLICATION_CREDENTIALS="/path/to/service-account.json"

# ── Option B: Gemini Developer API / AI Studio (uses an API key instead of Vertex) ──
# Leave the GOOGLE_CLOUD_* vars above unset to use this path.
# GEMINI_API_KEY="MY_GEMINI_API_KEY"

# ── Server ──
# Port the API/server listens on (Cloud Run injects PORT automatically).
# PORT="3001"

# APP_URL: The URL where this applet is hosted (self-referential links, callbacks).
APP_URL="MY_APP_URL"
